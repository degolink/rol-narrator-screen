DEBUG=True
SECRET_KEY=yoursecretkeyhere

DB_NAME=rol_narrator_screen
DB_USER=rol_user
DB_PASSWORD=rol_password

FRONTEND_DOMAIN=rol.local

# Recording Timezone (IANA timezone name, e.g. UTC, America/Bogota, America/New_York)
# RECORDING_TIMEZONE=UTC

# Email Settings (Local with Mailpit — default when no Resend key is set)
# EMAIL_HOST=mailpit
# EMAIL_PORT=1025
# EMAIL_USE_TLS=False

# Email Settings (Real — uncomment to send via Brevo SMTP)
# Setting EMAIL_HOST_PASSWORD activates real email automatically; Mailpit is used otherwise.
# 1. Sign up at https://brevo.com
# 2. Verify your sender email at Settings > Senders & IPs
# 3. Get your SMTP key at Settings > SMTP & API > SMTP tab
# EMAIL_HOST=smtp-relay.brevo.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-brevo-login-email
# EMAIL_HOST_PASSWORD=your-brevo-smtp-key
# DEFAULT_FROM_EMAIL=your-verified-sender-email

# D&D 5e API Settings
MONGODB_URI=mongodb://mongo:27017/dnd5e
